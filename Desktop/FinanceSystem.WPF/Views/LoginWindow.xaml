<!-- Màn hình đăng nhập WPF - toàn bộ text tiếng Việt -->
<Window x:Class="FinanceSystem.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Tài Chính Cá Nhân – Đăng Nhập"
        Height="480" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                  Color="#000000" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel Margin="40,36" VerticalAlignment="Center">

                <!-- Logo / Tiêu đề -->
                <TextBlock Text="💰" FontSize="40"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Tài Chính Cá Nhân"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Công cụ quản lý dành cho Admin"
                           FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,28"/>

                <!-- Thông báo lỗi -->
                <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                        CornerRadius="6" Padding="12,10" Margin="0,0,0,16"
                        Visibility="{Binding HasError,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " FontSize="14" Foreground="#DC2626"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="13" Foreground="#DC2626"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Email -->
                <TextBlock Text="Địa chỉ Email" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputBox}"
                         Margin="0,0,0,16"
                         IsEnabled="{Binding IsLoading,
                                     Converter={StaticResource InvertBoolConverter}}"/>

                <!-- Mật khẩu - dùng event thay vì binding vì lý do bảo mật -->
                <TextBlock Text="Mật Khẩu" Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="PasswordBox"
                             Padding="12,8"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,24"
                             IsEnabled="{Binding IsLoading,
                                         Converter={StaticResource InvertBoolConverter}}"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Nút đăng nhập -->
                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="15" Height="44">
                    <TextBlock Text="{Binding IsLoading,
                                       Converter={StaticResource LoadingTextConverter},
                                       ConverterParameter='Đang đăng nhập...|Đăng Nhập'}"/>
                </Button>

                <TextBlock Text="v1.0.0 – Finance System Admin"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
