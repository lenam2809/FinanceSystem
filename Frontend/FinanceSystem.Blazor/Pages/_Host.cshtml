@page "/"
@namespace FinanceSystem.Blazor.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tài Chính Cá Nhân</title>
    <base href="~/" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="icon" href="favicon.ico" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        Đã xảy ra lỗi kết nối. <a href="">Tải lại trang</a> hoặc chờ trong giây lát.
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        // Hàm khởi tạo biểu đồ Chart.js từ Blazor
        window.createChart = function (canvasId, type, labels, data, backgroundColors, label) {
            const ctx = document.getElementById(canvasId);
            if (!ctx) return;
            // Hủy biểu đồ cũ nếu tồn tại
            const existing = Chart.getChart(canvasId);
            if (existing) existing.destroy();

            new Chart(ctx, {
                type: type,
                data: {
                    labels: labels,
                    datasets: [{
                        label: label,
                        data: data,
                        backgroundColor: backgroundColors,
                        borderColor: type === 'line' ? backgroundColors[0] : undefined,
                        borderWidth: type === 'line' ? 2 : 1,
                        fill: type === 'line'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: type === 'pie' ? 'right' : 'top' }
                    }
                }
            });
        };
    </script>
</body>
</html>
